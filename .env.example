# Copiar a .env y completar. TODO es opcional: sin un token, esa fuente queda
# inactiva y el sistema sigue funcionando en modo degradado (lo informa /api/health).

# --- Base de datos ---
# Desarrollo: sqlite (default, no requiere nada). Producción: Postgres (Supabase o VM).
# SOBERANA_DATABASE_URL=postgresql+psycopg://usuario:clave@host:5432/soberana
SOBERANA_DATABASE_URL=sqlite:///./soberana.db

# --- Global Fishing Watch (gratis, registro en https://globalfishingwatch.org/our-apis/) ---
# Habilita: heatmap de pesca, detecciones SAR, eventos (gaps/encuentros/loitering)
SOBERANA_GFW_API_TOKEN=

# --- aisstream.io (gratis, https://aisstream.io/) ---
# Habilita: AIS en vivo costero/Hidrovía + detector propio de gaps
SOBERANA_AISSTREAM_API_KEY=

# --- Earth Observation Group (gratis, registro en https://eogdata.mines.edu/) ---
# Habilita: luces nocturnas VIIRS (flota potera)
# OJO: desde mayo 2025 EOG exige además un client OpenID propio para descargas
# programáticas — se pide GRATIS por mail a eog@mines.edu (client_id + secret).
SOBERANA_EOG_USERNAME=
SOBERANA_EOG_PASSWORD=
SOBERANA_EOG_CLIENT_ID=
SOBERANA_EOG_CLIENT_SECRET=

# --- Frontend (frontend/.env o variable en Vercel) ---
# URL del backend; vacía = modo estático (capas de archivo + adsb.lol directo)
# VITE_API_URL=https://api.tu-dominio.org
